# 3. Create Database

Open MySQL Workbench

```sql
CREATE DATABASE carbon_emission_db;
USE carbon_emission_db;
```

---

# 4. backend/database/carbon_emission.sql

```sql
CREATE DATABASE IF NOT EXISTS carbon_emission_db;

USE carbon_emission_db;

CREATE TABLE buildings (

id INT PRIMARY KEY AUTO_INCREMENT,

building_name VARCHAR(100) NOT NULL,

building_type VARCHAR(50),

area DOUBLE,

floors INT,

location VARCHAR(100),

climatic_zone VARCHAR(50),

flooring VARCHAR(50),

insulation VARCHAR(50),

lighting VARCHAR(50),

hvac VARCHAR(50),

appliances VARCHAR(50),

material VARCHAR(50),

material_quantity DOUBLE,

electricity DOUBLE,

heating DOUBLE,

cooling DOUBLE,

created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP

);

CREATE TABLE emission_factors(

id INT PRIMARY KEY AUTO_INCREMENT,

material VARCHAR(50),

emission_factor DOUBLE

);

CREATE TABLE climatic_zones(

id INT PRIMARY KEY AUTO_INCREMENT,

zone VARCHAR(50),

energy_multiplier DOUBLE

);
```

Execute the above script.

